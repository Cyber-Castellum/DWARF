{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "runtime_credential_ceremony params",
  "type": "object",
  "required": ["output_dir"],
  "properties": {
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "pool_count": {
      "type": "integer",
      "minimum": 1
    },
    "testnet_magic": {
      "type": "integer",
      "minimum": 1
    },
    "kes_period_window": {
      "type": "integer",
      "minimum": 1
    },
    "deterministic_seed": {
      "type": "string",
      "minLength": 1
    },
    "cardano_testnet_bin": {
      "type": "string",
      "minLength": 1
    },
    "timeout_seconds": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "expect_exit": {
      "type": "integer"
    }
  },
  "additionalProperties": false
}
