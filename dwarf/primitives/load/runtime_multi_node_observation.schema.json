{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "runtime_multi_node_observation params",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runtime_metadata_path",
    "node_ids",
    "observation_window_seconds",
    "observation_primitives",
    "output_dir"
  ],
  "properties": {
    "runtime_metadata_path": {"type": "string", "minLength": 1},
    "node_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "observation_window_seconds": {"type": "number", "exclusiveMinimum": 0},
    "observation_primitives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["tip_state", "connection_state", "resource_profile", "syscall_trace"]
      }
    },
    "output_dir": {"type": "string", "minLength": 1},
    "sample_interval_seconds": {"type": "number", "exclusiveMinimum": 0},
    "network_magic": {"type": "integer"},
    "cardano_cli": {"type": "string", "minLength": 1},
    "connect_attempts": {"type": "integer", "minimum": 1},
    "timeout_seconds": {"type": "number", "exclusiveMinimum": 0},
    "expect_exit": {"type": "integer"}
  }
}
