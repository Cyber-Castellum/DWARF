{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "runtime_cardano_lsq_extract params",
  "type": "object",
  "required": [
    "socket_path",
    "network_magic",
    "era",
    "output_path"
  ],
  "properties": {
    "socket_path": { "type": "string", "minLength": 1 },
    "network_magic": { "type": "integer", "minimum": 0 },
    "era": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "string", "minLength": 1 }
      ]
    },
    "output_path": { "type": "string", "minLength": 1 },
    "debug_raw_response_path": { "type": "string", "minLength": 1 },
    "result_json_path": { "type": "string", "minLength": 1 },
    "timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "expect_exit": { "type": "integer" }
  },
  "additionalProperties": false
}
