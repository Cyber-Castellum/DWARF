{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "runtime_snapshot_substrate params",
  "type": "object",
  "required": ["output_dir"],
  "properties": {
    "runtime_metadata_path": { "type": "string", "minLength": 1 },
    "target_node": { "type": "string", "minLength": 1 },
    "snapshot_path": { "type": "string", "minLength": 1 },
    "output_dir": { "type": "string", "minLength": 1 },
    "stop_node_during_capture": { "type": "boolean" },
    "healthy_timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "corruption_mode": { "type": "string", "enum": ["zero_range", "truncate", "flip_bits"] },
    "byte_offset": { "type": "integer", "minimum": 0 },
    "byte_count": { "type": "integer", "minimum": 1 },
    "truncate_bytes": { "type": "integer", "minimum": 1 },
    "xor_mask": { "type": "integer", "minimum": 0, "maximum": 255 },
    "timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "expect_exit": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
