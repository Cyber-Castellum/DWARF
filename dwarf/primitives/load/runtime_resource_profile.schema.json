{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "runtime_resource_profile params",
  "type": "object",
  "additionalProperties": false,
  "required": ["runtime_metadata_path"],
  "properties": {
    "helper_script": {"type": "string", "minLength": 1},
    "python_bin": {"type": "string", "minLength": 1},
    "timeout_seconds": {"type": "number", "exclusiveMinimum": 0},
    "expected_helper_exit": {"type": "integer"},
    "runtime_metadata_path": {"type": "string", "minLength": 1},
    "target_node": {"type": "string", "minLength": 1},
    "sample_count": {"type": "integer", "minimum": 1},
    "sample_interval_seconds": {"type": "number", "minimum": 0}
  }
}
