{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "runtime_network_impairment params",
  "type": "object",
  "required": ["from_node", "to_node", "output_dir"],
  "properties": {
    "runtime_metadata_path": { "type": "string", "minLength": 1 },
    "from_node": { "type": "string", "minLength": 1 },
    "to_node": { "type": "string", "minLength": 1 },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "jitter_ms": { "type": "integer", "minimum": 0 },
    "loss_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
    "partition": { "type": "boolean" },
    "healthy_timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "output_dir": { "type": "string", "minLength": 1 },
    "timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "expect_exit": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
