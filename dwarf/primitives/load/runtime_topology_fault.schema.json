{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "runtime_topology_fault params",
  "type": "object",
  "required": ["target_node", "output_dir"],
  "properties": {
    "runtime_metadata_path": { "type": "string", "minLength": 1 },
    "target_node": { "type": "string", "minLength": 1 },
    "sybil_node_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "adversary_node": { "type": "string", "minLength": 1 },
    "events_per_hour": { "type": "number", "minimum": 0 },
    "output_dir": { "type": "string", "minLength": 1 },
    "timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "expect_exit": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
