{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "runtime_txsubmission_probe params",
  "type": "object",
  "required": ["target_node", "output_dir"],
  "properties": {
    "runtime_metadata_path": { "type": "string", "minLength": 1 },
    "target_node": { "type": "string", "minLength": 1 },
    "target_host": { "type": "string", "minLength": 1 },
    "response_timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "receive_bytes": { "type": "integer", "minimum": 1 },
    "output_dir": { "type": "string", "minLength": 1 },
    "timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "expect_exit": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
