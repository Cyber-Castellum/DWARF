{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "runtime_bundle_diff params",
  "type": "object",
  "required": [
    "left_run_id",
    "right_run_id",
    "compare_relpaths"
  ],
  "properties": {
    "runs_dir": { "type": "string", "minLength": 1 },
    "left_run_id": { "type": "string", "minLength": 1 },
    "right_run_id": { "type": "string", "minLength": 1 },
    "compare_relpaths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "expected_helper_exit": { "type": "integer" },
    "helper_script": { "type": "string", "minLength": 1 },
    "python_bin": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
