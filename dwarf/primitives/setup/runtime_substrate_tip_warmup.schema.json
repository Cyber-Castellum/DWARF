{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "runtime_substrate_tip_warmup params",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runtime_metadata_path",
    "node_ids",
    "output_dir"
  ],
  "properties": {
    "runtime_metadata_path": {"type": "string", "minLength": 1},
    "node_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "output_dir": {"type": "string", "minLength": 1},
    "timeout_seconds": {"type": "number", "exclusiveMinimum": 0},
    "sample_interval_seconds": {"type": "number", "exclusiveMinimum": 0},
    "minimum_ready_nodes": {"type": "integer", "minimum": 1},
    "minimum_slot": {"type": "integer", "minimum": 1},
    "network_magic": {"type": "integer"},
    "cardano_cli": {"type": "string", "minLength": 1},
    "expect_exit": {"type": "integer"}
  }
}
