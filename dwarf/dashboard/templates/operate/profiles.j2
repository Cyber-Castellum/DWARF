{% extends "_base.j2" %}
{% block main %}
<span class="eyebrow">Operate</span>
<h1>Profiles</h1>
<p>Runtime profiles describe how Cardano nodes are deployed for a scenario run — implementation, node count, peer-sharing setting, and network. Each entry corresponds to a <code>dwarf/profiles/&lt;id&gt;/profile.yaml</code> on disk.</p>

<hr class="hairline">

{% if empty %}
<p class="empty-section-statement">
  No profiles found.
  <span class="empty-section-statement__cite">scanned <code>dwarf/profiles/</code>, 0 <code>profile.yaml</code> files</span>
</p>
{% else %}
{% for entry in entries %}
{% include "operate/_partials/_profile_entry.j2" %}
{% endfor %}
{% endif %}
{% endblock %}
